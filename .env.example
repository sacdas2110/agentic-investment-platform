# .env.example - Copy to .env and configure for your environment

# ============================================================
# Database Configuration
# ============================================================
DATABASE_URL=postgresql://investment_user:investment_password@localhost:5432/investment_db
DATABASE_POOL_SIZE=20
DATABASE_POOL_RECYCLE=3600
DATABASE_ECHO=false

# ============================================================
# Redis Configuration
# ============================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================
# Kafka Configuration
# ============================================================
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_GROUP_ID=investment-platform
KAFKA_AUTO_OFFSET_RESET=earliest

# ============================================================
# Qdrant Vector Database
# ============================================================
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=changeme
QDRANT_PREFER_GRPC=false
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ============================================================
# Keycloak Authentication
# ============================================================
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=investment_platform
KEYCLOAK_CLIENT_ID=api_gateway
KEYCLOAK_CLIENT_SECRET=changeme
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ============================================================
# S3 / MinIO Configuration
# ============================================================
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=investment-briefs
S3_REGION=us-east-1
S3_USE_SSL=false

# ============================================================
# Local LLM (Ollama)
# ============================================================
LLM_HOST=http://localhost:11434
LLM_MODEL=llama2
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024

# ============================================================
# API Gateway
# ============================================================
API_GATEWAY_HOST=0.0.0.0
API_GATEWAY_PORT=8000
API_GATEWAY_LOG_LEVEL=INFO
API_GATEWAY_WORKERS=4

# ============================================================
# Service Ports
# ============================================================
INGESTION_AGENT_PORT=8001
DOCUMENT_INTEL_AGENT_PORT=8002
RESEARCH_RAG_AGENT_PORT=8003
INVESTMENT_SCORER_PORT=8004
PORTFOLIO_ANALYTICS_PORT=8005
RISK_MONITOR_AGENT_PORT=8006
BRIEFING_GENERATOR_PORT=8007
COMPLIANCE_GOVERNANCE_PORT=8008

# ============================================================
# Security & JWT
# ============================================================
JWT_SECRET=your_super_secret_jwt_key_change_in_production_123456
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================================
# PDPL Compliance
# ============================================================
PDPL_ENABLED=true
ENCRYPTION_KEY=your_encryption_key_change_in_production
AUDIT_RETENTION_YEARS=7
DATA_MINIMIZATION_ENABLED=true

# ============================================================
# Rate Limiting
# ============================================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================================
# Monitoring & Observability
# ============================================================
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
OPENTELEMETRY_ENABLED=false
OPENTELEMETRY_ENDPOINT=http://localhost:4317

# ============================================================
# Feature Flags
# ============================================================
ENABLE_RAG_SEARCH=true
ENABLE_BRIEFING_GENERATION=true
ENABLE_PORTFOLIO_OPTIMIZATION=true
ENABLE_RISK_MONITORING=true
ENABLE_MARKET_DATA_INGESTION=true

# ============================================================
# Environment
# ============================================================
ENVIRONMENT=development
DEBUG=true
