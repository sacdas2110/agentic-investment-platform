# ============================================================
# Agentic Investment Platform - Environment Configuration
# ============================================================

# Database
DATABASE_URL=postgresql://investment_user:investment_password@postgres:5432/investment_db
DATABASE_ECHO=false
DATABASE_POOL_SIZE=20
DATABASE_POOL_RECYCLE=3600

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_TTL=3600
REDIS_MAX_CONNECTIONS=50

# Qdrant Vector DB
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_RESEARCH_DOCS=research_documents
QDRANT_COLLECTION_MARKET_REPORTS=market_reports
QDRANT_COLLECTION_STRATEGY_PAPERS=strategy_papers
QDRANT_VECTOR_SIZE=384
QDRANT_SIMILARITY_METRIC=cosine

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_CONSUMER_GROUP=investment_platform
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_MAX_POLL_RECORDS=100

# Keycloak
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=investment_platform
KEYCLOAK_CLIENT_ID=api_gateway
KEYCLOAK_CLIENT_SECRET=changeme
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# LLM Configuration
LLM_TYPE=ollama  # or vllm
LLM_HOST=http://ollama:11434
LLM_MODEL=llama2  # or mistral
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.7
LLM_TOP_P=0.9

# Embedding Model (for RAG)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# S3 / Object Storage
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_DOCUMENTS=investment-documents
S3_BUCKET_BRIEFS=investment-briefs
S3_USE_SSL=false

# Metabase
METABASE_URL=http://metabase:3000
METABASE_ADMIN_EMAIL=admin@investment.local
METABASE_ADMIN_PASSWORD=changeme

# API Gateway
API_GATEWAY_HOST=0.0.0.0
API_GATEWAY_PORT=8000
API_GATEWAY_WORKERS=4
API_GATEWAY_LOG_LEVEL=INFO
API_GATEWAY_CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Security
JWT_SECRET=your_super_secret_key_here_change_in_production_12345
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS

# PDPL Compliance
PDPL_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=2555  # 7 years
ENCRYPT_PII=true
CONSENT_VERIFICATION_ENABLED=true
DATA_MINIMIZATION_BATCH_SIZE=1000
DATA_MINIMIZATION_SCHEDULE=weekly

# Feature Flags
ENABLE_RAG_SEARCH=true
ENABLE_BRIEFING_GENERATION=true
ENABLE_PORTFOLIO_OPTIMIZATION=true
ENABLE_RISK_MONITORING=true
ENABLE_INVESTMENT_SCORING=true
ENABLE_DOCUMENT_INTEL=true

# Service Ports
INGESTION_AGENT_PORT=8001
DOCUMENT_INTEL_AGENT_PORT=8002
RESEARCH_RAG_AGENT_PORT=8003
INVESTMENT_SCORER_PORT=8004
PORTFOLIO_ANALYTICS_PORT=8005
RISK_MONITOR_AGENT_PORT=8006
BRIEFING_GENERATOR_PORT=8007
COMPLIANCE_GOVERNANCE_PORT=8008

# Slack Notifications (Optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_NOTIFICATIONS_ENABLED=false
SLACK_ERROR_CHANNEL=#errors
SLACK_ALERT_CHANNEL=#alerts

# Email (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@investment-platform.local

# Monitoring & Logging
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
ELASTIC_SEARCH_URL=http://elasticsearch:9200
ELASTIC_SEARCH_ENABLED=false

# Environment
ENVIRONMENT=development  # development, staging, production
DEBUG=true
LOG_LEVEL=INFO
